APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
PORT=8000

# Demo default: fast deterministic agents. Set to true only when you want live LLM calls.
USE_LIVE_LLM=false

# Optional Azure OpenAI reasoning provider.
# Requires USE_LIVE_LLM=true.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional OpenRouter reasoning provider.
# Requires USE_LIVE_LLM=true. Keep false for the fast hackathon demo path.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=ConsensusIQ

# Optional Microsoft Foundry IQ retrieval provider.
# Plug real Microsoft IQ credentials here; leave blank to use the curated public corpus fallback.
FOUNDRY_IQ_ENDPOINT=
FOUNDRY_IQ_API_KEY=
FOUNDRY_IQ_INDEX_NAME=
FOUNDRY_IQ_API_VERSION=2024-05-01-preview

# Optional Azure AI Search / Foundry IQ Search Service retrieval provider.
# Takes priority over FOUNDRY_IQ_* when all three required values are present.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_API_VERSION=2024-07-01
